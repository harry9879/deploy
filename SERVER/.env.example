# ==============================================================================
# FILE SHARING APPLICATION - ENVIRONMENT CONFIGURATION
# ==============================================================================
# This is an example configuration file. Copy this to .env and update values.
# NEVER commit the actual .env file to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# SERVER CONFIGURATION
# ------------------------------------------------------------------------------
PORT=5001
NODE_ENV=development
# Options: development, production, test

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION - MongoDB
# ------------------------------------------------------------------------------

# Option 1: Local MongoDB (for development with MongoDB Compass)
# Uncomment the line below to use local MongoDB
# MONGODB_URI=mongodb://localhost:27017/file-sharing-app

# Option 2: MongoDB Atlas (Cloud Database - Recommended for Production)
# Replace with your own Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/file-sharing-app?retryWrites=true&w=majority

# Example (DO NOT use this in production):
# MONGODB_URI=mongodb+srv://myuser:mypassword@cluster0.abc123.mongodb.net/file-sharing-app?retryWrites=true&w=majority

# ------------------------------------------------------------------------------
# JWT AUTHENTICATION CONFIGURATION
# ------------------------------------------------------------------------------
# Generate a strong secret key for production (at least 32 characters)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_characters
JWT_EXPIRE=3d
# Options: 1h, 24h, 7d, 30d, etc.

# ------------------------------------------------------------------------------
# ADMIN REGISTRATION CODE
# ------------------------------------------------------------------------------
# Users must provide this code during registration to become admin
# Change this to a strong, unique code in production
ADMIN_REGISTRATION_CODE=ADMIN2025SECRET

# ------------------------------------------------------------------------------
# EMAIL CONFIGURATION - SendGrid
# ------------------------------------------------------------------------------
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Use a verified sender in SendGrid
EMAIL_FROM=deepsinghharman8877@gmail.com

# Optional SMTP fallback for local development only
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=deepsinghharman8877@gmail.com
EMAIL_PASSWORD=

# ------------------------------------------------------------------------------
# FRONTEND URL CONFIGURATION
# ------------------------------------------------------------------------------
# Used for CORS configuration and email verification/download links

# Development
FRONTEND_URL=http://localhost:5173

# Production (Uncomment and update for deployment)
# FRONTEND_URL=https://your-app.vercel.app

# ------------------------------------------------------------------------------
# FILE UPLOAD CONFIGURATION
# ------------------------------------------------------------------------------
# All values are in bytes

# Maximum size per individual file (200MB)
MAX_FILE_SIZE=209715200
# 200 MB = 200 * 1024 * 1024 bytes

# Maximum total storage per user (500MB)
MAX_USER_STORAGE=524288000
# 500 MB = 500 * 1024 * 1024 bytes

# Maximum global storage for entire system (10GB)
MAX_GLOBAL_STORAGE=10737418240
# 10 GB = 10 * 1024 * 1024 * 1024 bytes

# File size reference:
# 1 MB  = 1048576 bytes
# 10 MB = 10485760 bytes
# 50 MB = 52428800 bytes
# 100 MB = 104857600 bytes
# 200 MB = 209715200 bytes
# 500 MB = 524288000 bytes
# 1 GB  = 1073741824 bytes
# 5 GB  = 5368709120 bytes
# 10 GB = 10737418240 bytes

# ------------------------------------------------------------------------------
# CLEANUP JOB CONFIGURATION
# ------------------------------------------------------------------------------
# Cron expression for automated file cleanup (removes expired files)
CLEANUP_CRON_SCHEDULE=0 2 * * *
# Default: Runs daily at 2:00 AM

# Cron expression format: * * * * *
# ┬ ┬ ┬ ┬ ┬
# │ │ │ │ │
# │ │ │ │ └─── Day of week (0-7) (Sunday = 0 or 7)
# │ │ │ └───── Month (1-12)
# │ │ └─────── Day of month (1-31)
# │ └───────── Hour (0-23)
# └─────────── Minute (0-59)

# Examples:
# 0 2 * * *    - Daily at 2:00 AM
# 0 */6 * * *  - Every 6 hours
# 0 0 * * 0    - Every Sunday at midnight
# */30 * * * * - Every 30 minutes

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
#
# 1. Copy this file and rename it to .env
#    $ cp .env.example .env
#
# 2. Update all placeholder values with your actual credentials
#
# 3. For MongoDB Atlas:
#    - Create account at https://www.mongodb.com/cloud/atlas
#    - Create a new cluster
#    - Add database user with password
#    - Get connection string and replace <username>, <password>, <cluster>
#
# 4. For Gmail with Nodemailer:
#    - Enable 2-Step Verification on your Google Account
#    - Generate App Password: https://myaccount.google.com/apppasswords
#    - Use the 16-character app password (without spaces)
#
# 5. Generate a strong JWT secret:
#    $ node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 6. Update FRONTEND_URL with your deployed frontend URL (for production)
#
# 7. Never commit the .env file to version control!
#    Make sure .env is in your .gitignore file
#
# ==============================================================================
